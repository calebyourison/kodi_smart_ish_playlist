<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.video.smartishplaylist"
       name="Smart-Ish Playlist"
       version="0.3.1"
       provider-name="Caleb Yourison">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.script"
               library="default.py"
               />

    <extension point="xbmc.service"
           library="service.py"
           start="startup" />

    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Smart-ish Playlist</summary>
        <description lang="en">Mimic smart list behavior with mixed media</description>
        <platform>all</platform>
        <assets>
            <icon>resources/media/icon.png</icon>
            <fanart>resources/media/fanart.jpg</fanart>
            <screenshot>resources/media/general.jpg</screenshot>
            <screenshot>resources/media/movies.jpg</screenshot>
            <screenshot>resources/media/tv_shows.jpg</screenshot>
        </assets>
    </extension>
</addon>