<?xml version="1.0" ?>
<settings version="1">
	<section id="script.video.smartishplaylist">

        <category id="general" label="32001" help="">
            <group id="1" label="">

                <setting id="build_at_startup" type="boolean" label="32002" help="32003">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>

                <setting id="auto_play" type="boolean" label="32004" help="32005">
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>

                <setting id="shuffle" type="boolean" label="32006" help="32007">
                    <dependencies>
	                    <dependency type="visible" setting="auto_play">true</dependency>
                    </dependencies>
                    <level>0</level>
                    <default>true</default>
                    <control type="toggle"/>
                </setting>

                <setting id="auto_quit" type="boolean" label="32008" help="32009">
                    <dependencies>
	                    <dependency type="visible" setting="auto_play">true</dependency>
                    </dependencies>
                    <level>0</level>
                    <default>false</default>
                    <control type="toggle"/>
                </setting>

                <setting id="auto_quit_minutes" type="integer" label="32010" help="32011">
                    <dependencies>
	                    <dependency type="visible" setting="auto_quit">true</dependency>
                    </dependencies>
                    <level>0</level>
	                <default>60</default>
	                <control type="edit" format="integer">
	                </control>
                </setting>

                <setting id="review_selections" type="action" label="32012" help="32013">
	                <level>0</level>
	                <default/>
	                <constraints>
		            <allowempty>true</allowempty>
	                </constraints>
	                <control type="button" format="action">
                        <data>RunScript(script.video.smartishplaylist,review_selections)</data>
	                </control>
                </setting>

			</group>
		</category>

        <category id="movies" label="32051" help="">
